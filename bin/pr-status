#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# ///
"""pr-status — Show CI checks, comments, and review state for a PR."""

import argparse
import json
import subprocess
import sys


def run_gh(*args: str) -> str:
    result = subprocess.run(
        ["gh", *args], capture_output=True, text=True
    )
    if result.returncode != 0:
        print(f"Error: {result.stderr.strip()}", file=sys.stderr)
        sys.exit(1)
    return result.stdout.strip()


def run_gh_json(*args: str) -> dict | list:
    return json.loads(run_gh(*args))


def detect_repo() -> str:
    return run_gh("repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner")


def detect_pr(repo: str) -> str:
    return run_gh("pr", "view", "--json", "number", "-q", ".number", "--repo", repo)


def fetch_pr_data(repo: str, pr_number: str) -> dict:
    fields = "state,mergedAt,mergedBy,statusCheckRollup,reviews,comments,mergeable,mergeStateStatus"
    return run_gh_json("pr", "view", "--json", fields, "--repo", repo, pr_number)


def fetch_inline_comments(repo: str, pr_number: str) -> list:
    try:
        return run_gh_json("api", f"repos/{repo}/pulls/{pr_number}/comments")
    except SystemExit:
        return []


def build_comment_index(pr_data: dict, inline_comments: list) -> dict:
    index = {}
    for c in pr_data.get("comments", []):
        index[c["id"]] = ("issue", c)
    for r in pr_data.get("reviews", []):
        index[r["id"]] = ("review", r)
    for c in inline_comments:
        index[c["id"]] = ("inline", c)
    return index


def first_meaningful_line(body: str, skip_prefixes: tuple = ("#", "**Project")) -> str:
    for line in body.split("\n"):
        stripped = line.strip()
        if stripped and not stripped.startswith(skip_prefixes):
            return stripped
    return ""


def truncate(s: str, max_len: int = 100) -> str:
    if len(s) > max_len:
        return s[: max_len - 3] + "..."
    return s


# --- Render functions ---

def render_checks(checks: list) -> None:
    """Render CI check status rollup with icon, name, status, and conclusion."""
    if not checks:
        return
    print("=== CHECKS ===")
    for c in checks:
        name = c.get("name", "?")
        status = c.get("status", "?")
        conclusion = c.get("conclusion", "—") or "—"
        if conclusion == "SUCCESS":
            icon = "✓"
        elif conclusion == "FAILURE":
            icon = "✗"
        elif status in ("IN_PROGRESS", "QUEUED"):
            icon = "⏳"
        else:
            icon = "·"
        print(f"  {icon} {name:45s} {status:12s} {conclusion}")
    print()


def render_bot_comments(comments: list, n: int) -> None:
    """Render issue-level comments (bot + human), grouped by author, showing last N per author."""
    if not comments:
        return
    by_author: dict[str, list] = {}
    for c in comments:
        author = c["author"]["login"]
        by_author.setdefault(author, []).append(c)
    label = "latest per bot" if n == 1 else f"last {n} per bot"
    print(f"=== BOT COMMENTS ({label}) ===")
    for author, items in by_author.items():
        for c in items[-n:]:
            cid = c.get("id", "?")
            summary = truncate(first_meaningful_line(c.get("body", "")))
            created = (c.get("createdAt") or "")[:16]
            print(f"  {author:30s} {cid}  {created}  {summary}")
    print()


def render_reviews(reviews: list, n: int) -> None:
    """Render PR reviews grouped by author, showing last N per reviewer with state icon."""
    if not reviews:
        return
    by_author: dict[str, list] = {}
    for r in reviews:
        author = r["author"]["login"]
        by_author.setdefault(author, []).append(r)
    label = "latest per reviewer" if n == 1 else f"last {n} per reviewer"
    print(f"=== REVIEWS ({label}) ===")
    for author, items in by_author.items():
        for r in items[-n:]:
            state = r["state"]
            if state == "APPROVED":
                icon = "✓"
            elif state == "CHANGES_REQUESTED":
                icon = "✗"
            else:
                icon = "·"
            rid = r.get("id", "?")
            ts = (r.get("submittedAt") or "")[:16]
            print(f"  {icon} {author:30s} {rid}  {state:20s} ({ts})")
            body = (r.get("body") or "").strip()
            if body:
                first_line = truncate(first_meaningful_line(body))
                if first_line:
                    print(f"    {first_line}")
    print()


def render_inline_comments(comments: list, n: int) -> None:
    """Render inline diff comments (Codewall, reviewdog, etc.) grouped by author."""
    if not comments:
        return
    by_author: dict[str, list] = {}
    for c in comments:
        author = c["user"]["login"]
        by_author.setdefault(author, []).append(c)
    label = "latest per author" if n == 1 else f"last {n} per author"
    print(f"=== INLINE COMMENTS ({label}) ===")
    for author, items in by_author.items():
        for c in items[-n:]:
            cid = c.get("id", "?")
            path = c.get("path", "?")
            line = c.get("line", "?")
            summary = truncate(first_meaningful_line(c.get("body", "")))
            short_path = path.rsplit("/", 1)[-1] if "/" in path else path
            print(f"  {author:30s} #{cid:<14} {short_path}:{line}")
            if summary:
                print(f"    {summary}")
    print()


def render_merge_state(pr_data: dict, skip: bool) -> None:
    """Render mergeability state — skipped for closed/merged PRs."""
    if skip:
        return
    mergeable = pr_data.get("mergeable")
    mstate = pr_data.get("mergeStateStatus")
    if not mergeable and not mstate:
        return
    if mergeable == "CONFLICTING":
        icon = "✗"
    elif mergeable == "MERGEABLE" and mstate in ("CLEAN", "HAS_HOOKS", "UNSTABLE"):
        icon = "✓"
    elif mstate in ("BEHIND", "BLOCKED", "DIRTY"):
        icon = "⚠"
    else:
        icon = "·"
    print("=== MERGE STATE ===")
    print(f"  {icon} mergeable={mergeable}  state={mstate}")
    print()


def render_summary(pr_data: dict, skip: bool) -> None:
    """Render final triage verdict: READY TO MERGE, BLOCKED, or PENDING."""
    if skip:
        return
    checks = pr_data.get("statusCheckRollup", [])
    reviews = pr_data.get("reviews", [])
    mergeable = pr_data.get("mergeable")

    # Use latest review per author for changes_requested detection
    latest_reviews = {}
    for r in reviews:
        author = r["author"]["login"]
        latest_reviews[author] = r
    latest = list(latest_reviews.values())

    all_done = all(c.get("status") == "COMPLETED" for c in checks)
    all_pass = all(c.get("conclusion") in ("SUCCESS", "NEUTRAL", "SKIPPED") for c in checks)
    approved = any(r["state"] == "APPROVED" for r in reviews)
    changes_req = any(r["state"] == "CHANGES_REQUESTED" for r in latest)

    if mergeable == "CONFLICTING":
        print("=== BLOCKED: merge conflicts with base branch ===")
    elif all_done and all_pass and approved and not changes_req:
        print("=== READY TO MERGE ===")
    elif all_done and not all_pass:
        failed = [c["name"] for c in checks if c.get("conclusion") == "FAILURE"]
        print(f"=== BLOCKED: {len(failed)} check(s) failed: {', '.join(failed)} ===")
    elif not all_done:
        pending = [c["name"] for c in checks if c.get("status") != "COMPLETED"]
        print(f"=== PENDING: {len(pending)} check(s) running: {', '.join(pending)} ===")


def render_single_comment(
    comment_id: str, index: dict, repo: str, pr_number: str
) -> None:
    """Look up a comment by ID and print its full body.

    Handles both node_id strings (from gh pr view --json) and numeric IDs
    (from gh api pulls/{n}/comments). Tries index lookup first, then
    numeric conversion, then 3-endpoint API fallback.
    """
    # Try raw value first (works for node_id strings and numeric strings
    # that were already stored as str keys in the index)
    entry = index.get(comment_id)
    if not entry and comment_id.isdigit():
        # Numeric ID from the user — try as int key (inline comments store int keys)
        entry = index.get(int(comment_id))
    if entry:
        ctype, data = entry
        _print_full_comment(ctype, data)
        return
    # Fallback: try all 3 API endpoints (works for numeric IDs only,
    # since node_ids aren't valid path components for REST endpoints)
    if comment_id.isdigit():
        for ctype, endpoint in [
            ("issue", f"repos/{repo}/issues/comments/{comment_id}"),
            ("inline", f"repos/{repo}/pulls/comments/{comment_id}"),
            ("review", f"repos/{repo}/pulls/{pr_number}/reviews/{comment_id}"),
        ]:
            try:
                data = run_gh_json("api", endpoint)
                _print_full_comment(ctype, data)
                return
            except SystemExit:
                continue
    print(f"Comment #{comment_id} not found.", file=sys.stderr)
    sys.exit(1)


def _print_full_comment(ctype: str, data: dict) -> None:
    """Print the full body of a single comment, handling field-name variance.

    GitHub's API uses different field names depending on the endpoint:
      - reviews/issue comments: data["author"]["login"]
      - inline comments: data["user"]["login"]
    Similarly for timestamps: createdAt vs submittedAt vs created_at.
    """
    print(f"=== COMMENT #{data.get('id', '?')} ({ctype}) ===")
    if ctype == "inline":
        path = data.get("path", "?")
        line = data.get("line", "?")
        print(f"Path: {path}:{line}")
    # Author field varies by endpoint
    author_obj = data.get("author") or data.get("user") or {}
    author = author_obj.get("login", "?")
    print(f"Author: {author}")
    created = data.get("created_at") or data.get("submittedAt") or data.get("createdAt") or ""
    if created:
        print(f"Created: {created}")
    print()
    print(data.get("body", ""))


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="pr-status",
        description="Show CI checks, comments, and review state for a PR.",
    )
    parser.add_argument("pr_number", nargs="?", default=None, help="PR number (default: auto-detect from current branch)")
    parser.add_argument("-R", "--repo", default=None, help="GitHub repo OWNER/REPO (default: auto-detect from CWD)")
    # NOTE: Accepts str (not int) because GitHub returns different ID shapes:
    #   - reviews/issue comments: node_id strings like "PRR_kwDORrrV687-51V0"
    #   - inline comments: numeric ints like "3229553163"
    # The lookup tries the raw value, then int conversion, then 3-endpoint fallback.
    parser.add_argument("--show-comment", type=str, default=None, metavar="ID", help="Print full body of a specific comment by ID (node_id or numeric)")
    parser.add_argument("--comments", type=int, default=1, metavar="N", help="Show the last N comments/reviews per author (default: 1, latest only)")
    args = parser.parse_args()

    repo = args.repo or detect_repo()
    pr_number = args.pr_number or detect_pr(repo)

    pr_data = fetch_pr_data(repo, pr_number)
    inline_comments = fetch_inline_comments(repo, pr_number)
    index = build_comment_index(pr_data, inline_comments)

    if args.show_comment is not None:
        render_single_comment(args.show_comment, index, repo, pr_number)
        return

    # Normal triage output
    checks = pr_data.get("statusCheckRollup", [])
    reviews = pr_data.get("reviews", [])
    bot_comments = pr_data.get("comments", [])

    pr_state = pr_data.get("state", "OPEN")
    is_closed = pr_state in ("MERGED", "CLOSED")

    if is_closed:
        merged_at = pr_data.get("mergedAt")
        if pr_state == "MERGED" and merged_at:
            merged_by = pr_data.get("mergedBy", {}).get("login", "?")
            print(f"=== MERGED by {merged_by} at {merged_at[:16]} ===")
        else:
            closed_at = pr_data.get("closedAt", "?")[:16]
            print(f"=== CLOSED (not merged) at {closed_at} ===")

    render_checks(checks)
    render_bot_comments(bot_comments, args.comments)
    render_reviews(reviews, args.comments)
    render_inline_comments(inline_comments, args.comments)
    render_merge_state(pr_data, skip=is_closed)
    render_summary(pr_data, skip=is_closed)


if __name__ == "__main__":
    main()
